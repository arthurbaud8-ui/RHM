# RHM - Variables pour Docker Compose
# Configuration : ./scripts/setup-env.sh   puis   docker-compose up -d --build
# Ou copier : cp .env.example .env puis éditer.

# CORS : origine autorisée par l'API (URL du site). Pas de slash final.
# Prod : https://rhm.example.com  |  Local : http://localhost:8080
CORS_ORIGIN=http://localhost:8080

# JWT : secret pour signer les tokens. Générer avec : openssl rand -base64 32
# Le script scripts/setup-env.sh le génère automatiquement.
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Build frontend : URL de l'API appelée par le navigateur.
# Docker (tout derrière nginx) : /api  |  Backend sur autre domaine : https://api.example.com/api
VITE_API_URL=/api

# OpenAI (obligatoire pour la génération de tests et l'analyse de CV en Docker)
# Sans clé : pas de test technique auto à la création d'offre, pas d'analyse CV ni d'évaluation de code.
# Créer une clé sur https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Base de données PostgreSQL (optionnel)
# Si défini : l'API utilise la DB. Sur Fly : configuré automatiquement par "fly postgres attach".
# Local : postgres://user:pass@localhost:5432/rhm  (ou laisser vide pour mémoire + JSON)
# DATABASE_URL=

# Persistance des données (fichier JSON, si DATABASE_URL non défini). En Docker : /data/rhm-data.json avec volume rhm-data
# DATA_FILE=/data/rhm-data.json

# Optionnel : upload et rate limiting
# UPLOAD_MAX_SIZE=10485760
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=500
