# Environment
NODE_ENV=development
PORT=3001

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# CORS & frontend (liens dans les emails)
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Email transactionnel (SMTP). Si non configuré, les emails sont loggés mais non envoyés.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=RHM <noreply@example.com>

# Upload
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_FORMATS=pdf,doc,docx,txt

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# IA : Groq (gratuit) ou OpenAI. Priorité : GROQ_API_KEY > OPENAI_API_*
# Groq : clé sur https://console.groq.com/keys — mettre soit GROQ_API_KEY soit OPENAI_API_KEY
GROQ_API_KEY=
# ou (équivalent pour Groq) :
OPENAI_API_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=
AI_MODEL=llama-3.1-8b-instant

# Base de données PostgreSQL (optionnel)
# Si défini : l'API utilise la DB. Sinon : stockage en mémoire + fichier JSON.
# Local : postgres://user:pass@localhost:5432/rhm
# Déployé sur Fly : déjà configuré via "fly postgres attach" (secret DATABASE_URL).
# DATABASE_URL=